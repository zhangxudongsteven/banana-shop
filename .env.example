# Tale Authentication Configuration (tale-js-sdk v1.1.1)
# Get your credentials from your Tale admin panel
TALE_BASE_URL=https://your-tale-api-url.com
TALE_APP_KEY=your_app_key_here
TALE_APP_SECRET=your_app_secret_here

# ========== Volcengine Ark API Configuration ==========
# Get your API key at https://console.volcengine.com/iam/aksk/
# Volcengine provides unified API for image generation, vision understanding, image editing, and video generation
VOLCENGINE_API_KEY=your_volcengine_api_key_here

# Volcengine Base URL (Optional)
# Defaults to Beijing region endpoint
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Volcengine Model Configuration (Optional)
# Image Generation Model - defaults to doubao-seedream-5-0-260128
VOLCENGINE_IMAGE_MODEL=doubao-seed-2-0-lite-260215

# Chat/Vision Model - defaults to doubao-seed-2-0-lite-260215 (supports vision understanding)
VOLCENGINE_CHAT_MODEL=doubao-seed-2-0-lite-260215

# Video Generation Model - defaults to doubao-seedance-1-5-pro-251215
VOLCENGINE_VIDEO_MODEL=doubao-video-1

# Image Editing Model (SeedEdit) - defaults to doubao-seedream-5-0-260128
# Uses instruction-based editing instead of mask-based editing
VOLCENGINE_EDIT_MODEL=doubao-seededit-3-0
